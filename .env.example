# --- LLM provider (provider-agnostic) ---
# "anthropic" uses the Anthropic SDK with a custom base_url (e.g. MiniMax M3).
# "openai"    uses the OpenAI SDK with a custom base_url (OpenRouter/DeepSeek today,
#             SynapticaAI later — it will be OpenAI-compatible, so just a config swap).
LLM_PROVIDER=anthropic

# Base URL of the compatible endpoint. Leave blank to use the SDK default
# (api.anthropic.com / api.openai.com).
LLM_BASE_URL=

LLM_API_KEY=
LLM_MODEL=MiniMax-M3

# Optional: cap tokens / temperature for planning calls.
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0

# --- Agent reliability caps / guardrails ---
AGENT_MAX_STEPS=25
AGENT_RETRY_MAX=3
AGENT_LOOP_WINDOW=3
AGENT_DOMAIN_ALLOWLIST=localhost,127.0.0.1,www.saucedemo.com
AGENT_CONFIRM_SENSITIVE=false
AGENT_HEADLESS=true

# --- Storage ---
DB_PATH=./data/agent.db
SCREENSHOT_DIR=./data/screenshots

# --- Local sandbox ---
SANDBOX_PORT=8000
